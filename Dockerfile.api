# API-only image for Railway/Render when the frontend is on Vercel.
# Build context = repo root (not /backend). Chromium comes with the base image.
FROM mcr.microsoft.com/playwright/python:v1.49.1-jammy

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

ENV PORT=8000
ENV SERVE_FRONTEND=0
EXPOSE 8000

# Shell expands PORT. Clear any Railway dashboard Start Command override.
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"]
