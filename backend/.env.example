# AI provider
AI_PROVIDER=gemini

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
# If overloaded, try lighter models first (free tier shares quota across models)
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.5-pro
GEMINI_MAX_RETRIES=5
GEMINI_RATE_LIMIT_RETRIES=2
# Optional: use a single model to save quota attempts
# GEMINI_FALLBACK_MODELS=
GEMINI_RETRY_BASE_SECONDS=2
GEMINI_MODEL_SWITCH_DELAY=3
GEMINI_FINAL_COOLDOWN_SECONDS=12

# GitHub profile in CV header when not parsed from the document
DEFAULT_GITHUB_USERNAME=your-github-username

# Optional Anthropic (not used by default)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6
